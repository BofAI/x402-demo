# X402 Demo - TypeScript / New SDK
# Copy this file to .env and fill in your values.
# This demo is scoped to TRON Nile.

# Client wallet: holds the TRC-20 test asset used for payment.
TRON_CLIENT_PRIVATE_KEY=your_nile_client_private_key_here

# Facilitator wallet: holds TRX for settlement gas/energy.
TRON_FACILITATOR_PRIVATE_KEY=your_nile_facilitator_private_key_here

# Recipient address for the protected resource server.
PAY_TO_ADDRESS=your_tron_pay_to_address_here

# Optional TronGrid API key to avoid RPC limits.
TRON_GRID_API_KEY=

# Demo service ports.
SERVER_PORT=8010
FACILITATOR_PORT=8011
SERVER_URL=http://localhost:8010
FACILITATOR_URL=http://localhost:8011

# Optional client override.
ENDPOINT=/protected-nile

# -----------------------------------------------------------------------------
# A2A Demo Settings (optional)
# -----------------------------------------------------------------------------

# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here
