# X402 Demo - TypeScript / New SDK
# Copy this file to .env and fill in your values.
# Default path is TRON Nile, with optional BSC testnet support.

# Client wallet: holds the TRC-20 test asset used for payment.
TRON_CLIENT_PRIVATE_KEY=your_nile_client_private_key_here

# Facilitator wallet: holds TRX for settlement gas/energy.
TRON_FACILITATOR_PRIVATE_KEY=your_nile_facilitator_private_key_here

# Recipient address for the protected resource server.
PAY_TO_ADDRESS=your_tron_pay_to_address_here

# Optional TronGrid API key to avoid RPC limits.
TRON_GRID_API_KEY=

# Demo service ports.
SERVER_PORT=8000
FACILITATOR_PORT=8001
SERVER_URL=http://localhost:8000
FACILITATOR_URL=http://localhost:8001
MCP_PORT=4022
MCP_SERVER_URL=http://localhost:4022
MCP_TOOL=get_weather
FACILITATOR_RETRY_MS=3000

# Optional client override.
ENDPOINT=/protected-nile
PREFERRED_NETWORK=

# -----------------------------------------------------------------------------
# BSC Testnet Demo Settings (optional)
# -----------------------------------------------------------------------------

# BSC client wallet: holds the ERC-20 test asset used for payment.
BSC_CLIENT_PRIVATE_KEY=

# BSC facilitator wallet: holds testnet BNB for settlement gas.
BSC_FACILITATOR_PRIVATE_KEY=

# BSC recipient address for the protected resource server.
BSC_PAY_TO=

# BSC testnet RPC.
BSC_TESTNET_RPC_URL=

# BSC public demo pricing. Defaults use built-in registry assets on testnet.
BSC_TEST_PRICE=0.0001
BSC_TEST_ASSETS=USDT,USDC

# -----------------------------------------------------------------------------
# A2A Demo Settings (optional)
# -----------------------------------------------------------------------------

# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here
