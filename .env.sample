# X402 Demo - Environment Variables
# Copy this file to .env and fill in your values.
# This demo can run TRON permit / gasfree flows plus BSC exact flows.

# Agent wallet setup
# TRON signers still resolve keys from agent-wallet.
# BSC demo paths can also use the local private-key env vars below.
# Run `npx agent-wallet init` if you want TRON support locally.

# Resource server / client
SERVER_URL=http://localhost:8000
ENDPOINT=/protected-nile
PREFERRED_NETWORK=
HTTP_TIMEOUT_SECONDS=60

# Pay To Address (Required for server - TRON)
# The TRON address that will receive payments
PAY_TO_ADDRESS=your_tron_address_here

# BSC payee for exact / exact_permit endpoints
# The BSC exact demo route uses DHLU (ERC-3009 / eip3009) for Coinbase v2 interop.
BSC_PAY_TO_ADDRESS=your_evm_address_here
# Optional alias supported by the server
# BSC_PAY_TO=your_evm_address_here

# Service ports and wiring
FACILITATOR_URL=http://localhost:8001
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
FACILITATOR_HOST=0.0.0.0
FACILITATOR_PORT=8001
BSC_CLIENT_PRIVATE_KEY=your_bsc_client_private_key_here
BSC_FACILITATOR_PRIVATE_KEY=your_bsc_facilitator_private_key_here
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# Facilitator API Key (Optional)
# When facilitator requires X-API-KEY for auth, set this to match the key in facilitator's api_keys table
# FACILITATOR_API_KEY=your_api_key_here

# GasFree API Configuration (Optional)
# Used for gasless transactions via GasFree service
# Global keys (fallback)
# GASFREE_API_KEY=your_gasfree_api_key_here
# GASFREE_API_SECRET=your_gasfree_api_secret_here

# Network specific keys (e.g. for Nile)
# GASFREE_API_KEY_NILE=your_gasfree_api_key_nile_here
# GASFREE_API_SECRET_NILE=your_gasfree_api_secret_nile_here

# GASFREE_API_KEY_SHASTA=your_gasfree_api_key_shasta_here
# GASFREE_API_SECRET_SHASTA=your_gasfree_api_secret_shasta_here

# GASFREE_API_KEY_MAINNET=your_gasfree_api_key_mainnet_here
# GASFREE_API_SECRET_MAINNET=your_gasfree_api_secret_mainnet_here

# -----------------------------------------------------------------------------
# A2A Demo Settings
# -----------------------------------------------------------------------------

# Google Gemini API Key (Required for A2A Demo)
# Get it at https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_API_KEY=your_google_api_key_here

# Facilitator Service URL (Required for A2A Demo)
# Responsible for on-chain verification and settlement
FACILITATOR_URL=https://facilitator.bankofai.io
